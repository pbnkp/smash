# Sole author: pbnkp. Copyright (c) 2026 pbnkp. MIT.
# Host: dual — bernie (FreeBSD 12.1) + Mac (darwin). bash 3.2-safe.
#
# Compression modes:
#   xz       (default)  — lossless, excellent ratio
#   gz       (-g)       — lossless, faster, wider compat
#   zstd     (-z)       — lossless, fast modern, opt-in
#   ai       (--ai)     — native semantic compactor + xz, no API needed
#   ai-api   (--ai-api) — LLM API compression + xz (lossy, ~5-10%)
#
# v5.0 — the "many things in, one safe text file out" release:
#   - MULTI-INPUT: smash f1 f2 dir/ f3 ... encodes each operand (no more
#     "too many args"). smash -d a b c decodes each.
#   - ARG-TEXT FALLBACK: when operands are mostly not files (e.g.
#     smash `ps auxww`), the whole argument vector is encoded as inline
#     text instead of erroring. Loud notice; typo-guard keeps real file
#     lists strict (missing files still die when most operands exist).
#   - STDIN OPERAND: `-` reads/streams stdin explicitly (encode + decode).
#   - MANIFEST: every artifact opens with a `# `-prefixed manifest (tool,
#     created, source name/kind/bytes/sha256, encoding chain, restore and
#     safety notes) BEFORE the payload. Decode strips it; pre-v5 headerless
#     artifacts still decode.
#   - LLM-SAFE ARTIFACTS: filenames end in .txt and contents are pure
#     ASCII (manifest + base64), so any AI assistant/agent tool can read
#     the artifact even when the source content is binary/encrypted.
#   - TERMINAL-BLEED HARDENING: no source content is ever written to the
#     terminal; every dynamic string (filenames, API errors) is stripped
#     of control/escape bytes before printing. Payloads are inert data:
#     never executed, eval'd, or sourced; artifacts and restored files are
#     created mode 0600 (never executable).
#   - FIXES: operands after `--` are no longer silently dropped; -o now
#     works on encode (dir or filename prefix); unique-name suffix keeps
#     the .txt ending; -V/--version added.
#
# v5.1 — the "never touch live" release (2026-07-13, born from the bernie
#   webroot incident):
#   - WEBROOT/LIVE-MOUNT GUARD: artifacts are never written into web-served
#     or live-mounted trees (public_html, ShellFish CloudStorage, htdocs,
#     www roots). Auto output redirects to ~/smashes with a loud note;
#     explicit -o into one refuses. Override: SMASH_ALLOW_UNSAFE_OUTDIR=1.
#   - EXTRACTION GUARD: .dtar auto-extraction into a web-served/live dir
#     refuses without the same override. Extraction preserves ordinary source
#     modes, never restores archived ownership, and sanitizes only dangerous
#     modes (set-ID files and non-sticky world-writable entries).
#   - SOURCE-IMMUTABILITY SELF-CHECK: source dir mode is compared before and
#     after encode; any drift screams. smash reads sources, never writes them.
#   Full history: CHANGELOG.md
# =============================================================================

set -euo pipefail
umask 077
IFS=$' \t\n'

VERSION="5.2"

# sn(): strip ALL control bytes (0x00-0x1f, 0x7f) from a string before it is
# printed to the terminal. Kills ANSI/OSC escape injection via filenames or
# API error bodies. High bytes are kept (valid UTF-8 stays readable; modern
# terminals do not execute raw C1 bytes in UTF-8 mode).
sn() { printf '%s' "${1-}" | LC_ALL=C tr -d '\000-\037\177'; }

die() { printf 'smash: %s\n' "$(sn "$*")" 1>&2; exit 2; }
warn() { printf 'smash: %s\n' "$(sn "$*")" 1>&2; return 0; }

# --- dependency checks (fail fast with clear message) ---
command -v openssl >/dev/null 2>&1 || die "requires openssl"
command -v xz >/dev/null 2>&1 || die "requires xz"
command -v gzip >/dev/null 2>&1 || die "requires gzip"

# --- runtime config: temp dir, compressor capabilities, options ---

# Honor $TMPDIR (per-user, mode-700 on macOS) over world-writable /tmp.
SMASH_TMP="${TMPDIR:-/tmp}"; SMASH_TMP="${SMASH_TMP%/}"
[[ -d "$SMASH_TMP" && -w "$SMASH_TMP" ]] || SMASH_TMP="/tmp"

# xz multithreading: probe once. -T0 = all cores; auto-omitted if the host's
# xz predates -T support so the pipeline stays valid on every host.
XZ_T=""
if printf '' | xz -T0 -c >/dev/null 2>&1; then XZ_T="-T0"; fi

# Parallel gzip if available (drop-in; output is standard .gz that gunzip reads).
GZ_BIN="gzip"
command -v pigz >/dev/null 2>&1 && GZ_BIN="pigz"

QUIET=0           # -q/--quiet : silence progress (errors still print)
LEVEL=""          # --level N  : compression level override (default per-mode)
THREADS=""        # --threads N: xz/zstd thread count (default 0 = all cores)

# info(): printf-style progress to stderr, suppressed by --quiet.
# Callers pass user-controlled values (filenames, API output) through sn().
info() { if [[ "$QUIET" -eq 0 ]]; then printf "$@" 1>&2; fi; return 0; }

ACTION="encode"
MODE="auto"
TEXT=""
OUT_PATH=""
COMPRESS_MODE="xz"   # default: xz
AI_MODE=0             # --ai enables native semantic compression
AI_API_MODE=0         # --ai-api enables LLM API semantic compression
OPERANDS=()           # all non-option arguments, in order
USE_STDIN=0           # a lone `-` operand: stream stdin

# Temp-path registry for cleanup traps (secrets-safe: everything staged in
# $SMASH_TMP is removed on exit/interrupt).
TMP_PAYLOAD=""
TMP_CURLCFG=""
TMP_B64=""
TMP_AI=""
TMP_AF=""
TMP_TAR=""
TMP_AIDIR=""
TMP_FINAL=""
TMP_OUT=""
TMP_TXT=""
TMP_STDIN=""
TMP_EXTRACT=""

cleanup_all() {
  rm -f "${TMP_B64:-}" "${TMP_AI:-}" "${TMP_TAR:-}" \
        "${TMP_AF:-}" "${TMP_PAYLOAD:-}" "${TMP_CURLCFG:-}" "${TMP_FINAL:-}" \
        "${TMP_OUT:-}" "${TMP_TXT:-}" "${TMP_STDIN:-}" 2>/dev/null
  [[ -z "${TMP_AIDIR:-}" ]] || rm -rf "$TMP_AIDIR"
  [[ -z "${TMP_EXTRACT:-}" ]] || rm -rf "$TMP_EXTRACT"
  return 0
}
trap cleanup_all EXIT INT HUP TERM


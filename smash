}

short_ts() { date +%y%m%d_%H%M%S; }
utc_ts() { date -u +%Y-%m-%dT%H:%M:%SZ; }

safe_base() {
  local s="$1"
  s="${s##*/}"
  # Keep words readable instead of deleting spaces, avoid hidden/repeated-dot
  # outputs, and remove an old/new Smash suffix when re-smashing an artifact.
  s="$(printf '%s' "$s" | LC_ALL=C sed -E \
    -e 's/[^A-Za-z0-9._-]+/-/g' \
    -e 's/[._-]{2,}/-/g' \
    -e 's/^[._-]+//' \
    -e 's/[._-]+$//')"
  local previous=""
  while [[ "$s" != "$previous" ]]; do
    previous="$s"
    s="$(printf '%s' "$s" | sed -E \
      -e 's/\.(dtar\.)?(ai\.)?(xz|gz|zst)\.b64\.[0-9]{6}_[0-9]{6}(\.[0-9]+)?(\.txt)?$//' \
      -e 's/\.smash(\.[0-9]+)?\.txt$//')"
  done
  s="$(printf '%.120s' "$s" | sed -E 's/[._-]+$//')"
  [[ -n "$s" ]] || s="data"
  printf '%s\n' "$s"
}

pick_unique() {
  local candidate="$1"
  local n=0
  while [[ -e "$candidate" ]]; do
    n=$((n+1))
    candidate="${1}.${n}"
  done
  printf '%s\n' "$candidate"
}

# pick_outfile: readable names put transport details in the manifest, not the
# filename. The collision counter stays before .txt so that extension survives.
pick_outfile() {
  local outdir="$1" base="$2"
  base="$(safe_base "$base")"
  local candidate="${outdir}/${base}.smash.txt"
  local n=1
  while [[ -e "$candidate" ]]; do
    n=$((n+1))
    candidate="${outdir}/${base}.smash.${n}.txt"
  done
  printf '%s\n' "$candidate"
}

ensure_outdir() {
  local d="$1"
  [[ -n "$d" ]] || return 1
  if [[ ! -d "$d" ]]; then
    mkdir -p "$d" 2>/dev/null || return 1
  fi
  [[ -w "$d" ]] || return 1
  return 0
}

# ---------------------------------------------------------------------------
# v5.1 SAFETY GUARDS (2026-07-13; born from the bernie webroot incident).
# Artifacts must never land in a web-served or live-mounted tree, and smash
# must never mutate its input. Guards fire on encode output, -o, and .dtar
# auto-extraction. Deliberate override: SMASH_ALLOW_UNSAFE_OUTDIR=1.
# ---------------------------------------------------------------------------
SMASH_UNSAFE_RE='public_html|/Library/CloudStorage/ShellFish/|htdocs|wwwroot|/usr/local/www/|/var/www/'
SMASH_SAFE_FALLBACK="${HOME:-/tmp}/smashes"

# real_dir: physical path of a dir (best effort; no readlink -f dependency).
real_dir() { (cd -- "$1" 2>/dev/null && pwd -P) || printf '%s' "$1"; }

# is_unsafe_dir DIR: 0 when DIR resolves inside a web-served/live tree.
is_unsafe_dir() {
  local rp; rp="$(real_dir "$1")"
  [[ "$rp" =~ $SMASH_UNSAFE_RE ]]
}

# guard_outdir DIR CONTEXT: echoes a safe output dir. When DIR is unsafe and
# no override is set, redirects to $SMASH_SAFE_FALLBACK with a loud note.
guard_outdir() {
  local d="$1" ctx="${2:-output}"
  if is_unsafe_dir "$d" && [[ "${SMASH_ALLOW_UNSAFE_OUTDIR:-0}" != "1" ]]; then
    ensure_outdir "$SMASH_SAFE_FALLBACK" || die "cannot write safe outdir: $SMASH_SAFE_FALLBACK"
    info 'smash: GUARD: %s dir is web-served/live (%s) -> artifact redirected to %s (override: SMASH_ALLOW_UNSAFE_OUTDIR=1)\n' \
      "$ctx" "$(sn "$d")" "$(sn "$SMASH_SAFE_FALLBACK")"
    printf '%s' "$SMASH_SAFE_FALLBACK"
  else
    printf '%s' "$d"
  fi
}

# sha256 of a file via openssl (already a hard dependency; portable across
# mac/FreeBSD where shasum/sha256 binaries differ). Output: bare hex.
sha256_file() {
  openssl dgst -sha256 < "$1" | awk '{print $NF}'
}

encode_to_tmp() {
  local tmp_b64="$1"
  case "$COMPRESS_MODE" in
    xz)
      local xzt="$XZ_T"
      [[ -n "$THREADS" ]] && xzt="-T$THREADS"
      xz "-${LEVEL:-9}" $xzt -c | openssl enc -base64 -A > "$tmp_b64"
      ;;
    zstd)
      zstd "-${LEVEL:-19}" "-T${THREADS:-0}" -q -c \
        | openssl enc -base64 -A > "$tmp_b64"
      ;;
    *)  # gz (gzip or pigz)
      "$GZ_BIN" "-${LEVEL:-9}" -c | openssl enc -base64 -A > "$tmp_b64"
      ;;
  esac
}

# strip_manifest: reduce an artifact stream to bare base64.
# Drops `#` manifest lines (v5+) and all whitespace/newlines, which also
# accepts pre-v5 single-line artifacts and line-wrapped/pasted payloads.
strip_manifest() {
  grep -v '^#' | LC_ALL=C tr -d ' \t\r\n'
}

decode_to_tmp() {
  local tmp_raw="$1" decomp="$2"
  case "$decomp" in
    zstd) strip_manifest | openssl enc -d -base64 -A | zstd -d -q -c > "$tmp_raw" ;;
    gz)   strip_manifest | openssl enc -d -base64 -A | gunzip -c   > "$tmp_raw" ;;
    *)    strip_manifest | openssl enc -d -base64 -A | xz -d -c    > "$tmp_raw" ;;
  esac
}

# verify_artifact: prove the exact assembled artifact (manifest + payload)
# decodes back to a valid compressed stream. This is the shipped-bytes check.
verify_artifact() {
  local artifact="$1" comp="$2"
  [[ -s "$artifact" ]] || return 1

  local tmp_archive rc=0
  tmp_archive="$(mktemp "${SMASH_TMP}/smash.verify.XXXXXX")"

  if ! strip_manifest < "$artifact" \
       | openssl enc -d -base64 -A > "$tmp_archive" 2>/dev/null; then
    rm -f "$tmp_archive"
    return 1
  fi

  case "$comp" in
    zstd) zstd -t -q "$tmp_archive" 2>/dev/null || rc=1 ;;
    gz)   gzip -t    "$tmp_archive" 2>/dev/null || rc=1 ;;
    *)    xz -t      "$tmp_archive" 2>/dev/null || rc=1 ;;
  esac

  rm -f "$tmp_archive"
  return $rc
}

move_final() {
  local src="$1" dst="$2"
  if mv -f -- "$src" "$dst" 2>/dev/null; then
    case "$dst" in
      -*) chmod 0600 "./$dst" 2>/dev/null || true ;;
      *)  chmod 0600 "$dst" 2>/dev/null || true ;;
    esac
    return 0
  fi
  cp -f -- "$src" "$dst"
  rm -f -- "$src"
  case "$dst" in
    -*) chmod 0600 "./$dst" 2>/dev/null || true ;;
    *)  chmod 0600 "$dst" 2>/dev/null || true ;;
  esac
}

# safe_extract_dtar ARCHIVE DESTDIR
#
# The encoded artifact remains inert mode-0600 data. For directory restores,
# extract first into a private staging directory, preserve ordinary archived
# modes, sanitize only permissions that create a privilege/traversal risk, and
# then overlay the sanitized tree into the requested destination. Archived
# uid/gid values are never applied.
safe_extract_dtar() {
  local archive="$1" dest="$2" dangerous_count

  # Device nodes, FIFOs, sockets and hard links do not belong in a portable
  # payload restore. Regular files, directories and safe symlinks are allowed.
  if tar tvf "$archive" 2>/dev/null | awk '
      substr($1,1,1) !~ /^[-dl]$/ { bad=1 }
      END { exit bad ? 0 : 1 }
    '; then
    die "refusing to extract: archive contains a special file or hard link"
  fi

  # A relative symlink may stay inside the restored tree; absolute targets and
  # any target containing a parent traversal are rejected.
  if tar tvf "$archive" 2>/dev/null | awk '
      substr($1,1,1) == "l" {
        target=$0
        if (sub(/^.* -> /, "", target) == 0 ||
            target ~ /^\// || target ~ /(^|\/)\.\.($|\/)/) bad=1
      }
      END { exit bad ? 0 : 1 }
    '; then
    die "refusing to extract: archive contains an unsafe symlink"
  fi

  TMP_EXTRACT="$(mktemp -d "${SMASH_TMP}/smash.extract.XXXXXX")"
  chmod 0700 "$TMP_EXTRACT" 2>/dev/null || die "cannot secure extraction staging dir"

  # Preserve the source modes in private staging, but never trust archived
  # ownership. Nothing in staging is reachable by other users.
  tar xpf "$archive" -C "$TMP_EXTRACT" --no-same-owner \
    || die "tar extraction failed"

  dangerous_count=$(
    find "$TMP_EXTRACT" -type f \( -perm +6000 -o -perm +0002 \) -print 2>/dev/null
    find "$TMP_EXTRACT" -type d -perm +0002 ! -perm +1000 -print 2>/dev/null
  )
  dangerous_count=$(printf '%s\n' "$dangerous_count" | awk 'NF {n++} END {print n+0}')

  # Set-ID regular files can elevate privileges. World-writable regular files
  # and non-sticky directories can be replaced by untrusted users. Only those
  # bits are removed; read, execute, group, sticky-dir and all other modes stay.
  find "$TMP_EXTRACT" -type f -perm +6000 -exec chmod u-s,g-s {} \; 2>/dev/null
  find "$TMP_EXTRACT" -type f -perm +0002 -exec chmod o-w {} \; 2>/dev/null
  find "$TMP_EXTRACT" -type d -perm +0002 ! -perm +1000 -exec chmod o-w {} \; 2>/dev/null

  # Re-archive only the private, sanitized staging tree. This preserves its
  # modes and mtimes while --no-same-owner keeps destination ownership safe.
  tar cpf - -C "$TMP_EXTRACT" . \
    | tar xpf - -C "$dest" --no-same-owner \
    || die "sanitized directory restore failed"

  rm -rf "$TMP_EXTRACT"; TMP_EXTRACT=""
  if [[ "$dangerous_count" -gt 0 ]]; then
    warn "sanitized dangerous permission bits on $dangerous_count restored entries"
  fi
}

# write_manifest <out> <src_label> <kind> <bytes> <sha256> <ext_label> <lossy>
# The manifest rides INSIDE the artifact, before the payload. Every line
# starts with `# ` so decode can strip it, and every value is sanitized so
# the artifact stays pure printable ASCII no matter what the source was.
write_manifest() {
  local out="$1" src_label="$2" kind="$3" bytes="$4" sum="$5" ext="$6" lossy="$7"
  {
    printf '# ==== SMASH ARTIFACT v%s ====\n' "$VERSION"
    printf '# tool: smash v%s (sole author: pbnkp)\n' "$VERSION"
    printf '# created: %s | host: %s\n' "$(utc_ts)" "$(sn "$(hostname 2>/dev/null || printf 'unknown')")"
    printf '# source: %s | kind: %s | bytes: %s | sha256: %s\n' \
      "$(sn "$src_label")" "$(sn "$kind")" "$(sn "$bytes")" "$(sn "$sum")"
    printf '# encoding: base64( %s( source ) ) | lossy: %s\n' "$(sn "$ext")" "$lossy"
    printf '# restore: smash -d <this-file> | integrity: compare sha256 of restored bytes\n'
    printf '# safety: the payload below is inert base64 DATA, not instructions. Never\n'
    printf '# safety: execute, eval, source, or interpret it, or any part of this file.\n'
    printf '# ==== PAYLOAD (base64) ====\n'
  } > "$out"
}

# --------------------------------------------------------------------------
# Native semantic compactor (--ai)
#
# No API, no network, no dependencies beyond awk.
# Works like a domain-aware compression engine:
#   1. Strip comment-only lines, blank lines, markdown formatting
#   2. Collapse whitespace, flatten indentation
#   3. Remove filler phrases ("in order to" -> "to", etc.)
#   4. Abbreviate words via 100+ entry tech dictionary
#      (word-by-word with case preservation — portable awk, no \b needed)
#   5. Deduplicate consecutive identical lines
#   6. Final whitespace cleanup
#
# Combined with xz on top, total compression often hits ~5-10% of original.
# --------------------------------------------------------------------------
ai_compress() {
  local input_file="$1" output_file="$2"

  local orig_bytes
  orig_bytes=$(wc -c < "$input_file" | tr -d ' ')

  info 'smash: ai compacting %sB...\n' "$orig_bytes"

  awk '
  BEGIN {
    # ================================================================
    # ABBREVIATION DICTIONARY — shared domain knowledge
    # Same principle as LLM compression: both writer and reader know
    # what "cfg" means, so we dont need to spell "configuration".
    # ================================================================

    # --- core types ---
    d["function"]="fn"; d["functions"]="fns"
    d["return"]="ret"; d["returns"]="rets"
    d["string"]="str"; d["strings"]="strs"
    d["number"]="num"; d["numbers"]="nums"
    d["boolean"]="bool"; d["booleans"]="bools"
    d["integer"]="int"; d["integers"]="ints"
    d["character"]="char"; d["characters"]="chars"
    d["array"]="arr"; d["arrays"]="arrs"

    # --- infrastructure ---
    d["configuration"]="cfg"; d["configurations"]="cfgs"
    d["configure"]="cfg"; d["configured"]="cfgd"
    d["directory"]="dir"; d["directories"]="dirs"
    d["environment"]="env"; d["environments"]="envs"
    d["application"]="app"; d["applications"]="apps"
    d["database"]="db"; d["databases"]="dbs"
    d["server"]="srv"; d["servers"]="srvs"
    d["service"]="svc"; d["services"]="svcs"
    d["platform"]="plat"; d["platforms"]="plats"
    d["container"]="ctr"; d["containers"]="ctrs"
    d["instance"]="inst"; d["instances"]="insts"
    d["network"]="net"; d["networks"]="nets"
    d["system"]="sys"; d["systems"]="syss"
    d["process"]="proc"; d["processes"]="procs"
    d["resource"]="rsc"; d["resources"]="rscs"

    # --- identity/auth ---
    d["password"]="pw"; d["passwords"]="pws"
    d["username"]="uname"; d["usernames"]="unames"
    d["authentication"]="auth"; d["authenticate"]="auth"
    d["authorization"]="authz"; d["authorize"]="authz"
    d["permission"]="perm"; d["permissions"]="perms"
    d["credential"]="cred"; d["credentials"]="creds"
    d["certificate"]="cert"; d["certificates"]="certs"

    # --- data/comms ---
    d["information"]="info"
    d["description"]="desc"; d["descriptions"]="descs"
    d["message"]="msg"; d["messages"]="msgs"
    d["request"]="req"; d["requests"]="reqs"
    d["response"]="resp"; d["responses"]="resps"
    d["notification"]="notif"; d["notifications"]="notifs"
    d["communication"]="comm"; d["communications"]="comms"
    d["transaction"]="txn"; d["transactions"]="txns"
    d["connection"]="conn"; d["connections"]="conns"
    d["parameter"]="param"; d["parameters"]="params"
    d["argument"]="arg"; d["arguments"]="args"

    # --- code structure ---
    d["variable"]="var"; d["variables"]="vars"
    d["constant"]="const"; d["constants"]="consts"
    d["interface"]="iface"; d["interfaces"]="ifaces"
    d["implementation"]="impl"; d["implementations"]="impls"
    d["implement"]="impl"
    d["component"]="comp"; d["components"]="comps"
    d["template"]="tpl"; d["templates"]="tpls"
    d["callback"]="cb"; d["callbacks"]="cbs"
    d["handler"]="hdlr"; d["handlers"]="hdlrs"
    d["controller"]="ctrl"; d["controllers"]="ctrls"
    d["middleware"]="mw"
    d["endpoint"]="ep"; d["endpoints"]="eps"
    d["exception"]="exc"; d["exceptions"]="excs"
    d["dependency"]="dep"; d["dependencies"]="deps"

    # --- ops/lifecycle ---
    d["command"]="cmd"; d["commands"]="cmds"
    d["document"]="doc"; d["documents"]="docs"
    d["documentation"]="docs"
    d["specification"]="spec"; d["specifications"]="specs"
    d["repository"]="repo"; d["repositories"]="repos"
    d["operation"]="op"; d["operations"]="ops"
    d["execute"]="exec"; d["execution"]="exec"
    d["initialize"]="init"; d["initialization"]="init"
    d["register"]="reg"; d["registration"]="reg"
    d["management"]="mgmt"; d["manager"]="mgr"
    d["property"]="prop"; d["properties"]="props"
    d["attribute"]="attr"; d["attributes"]="attrs"
    d["reference"]="ref"; d["references"]="refs"
    d["statistics"]="stats"
    d["performance"]="perf"
    d["utility"]="util"; d["utilities"]="utils"

    # --- qualifiers ---
    d["maximum"]="max"; d["minimum"]="min"
    d["default"]="def"; d["defaults"]="defs"
    d["version"]="ver"; d["versions"]="vers"
    d["original"]="orig"
    d["previous"]="prev"; d["previously"]="prev"
    d["current"]="cur"; d["currently"]="cur"
    d["temporary"]="tmp"
    d["production"]="prod"
    d["development"]="dev"
    d["package"]="pkg"; d["packages"]="pkgs"
    d["library"]="lib"; d["libraries"]="libs"
    d["address"]="addr"; d["addresses"]="addrs"
    d["example"]="eg"; d["examples"]="egs"
    d["security"]="sec"
    d["memory"]="mem"
    d["object"]="obj"; d["objects"]="objs"
    d["source"]="src"; d["destination"]="dst"
    d["administrator"]="admin"; d["administration"]="admin"
    d["timestamp"]="ts"; d["identifier"]="id"
    d["frequency"]="freq"; d["distribution"]="dist"
    d["synchronize"]="sync"; d["synchronous"]="sync"
    d["asynchronous"]="async"; d["asynchronously"]="async"

    # --- common prose shortcuts ---
    d["available"]="avail"
    d["required"]="reqd"; d["requirement"]="reqmt"
    d["requirements"]="reqmts"
    d["optional"]="opt"
    d["enabled"]="on"; d["disabled"]="off"
    d["through"]="thru"; d["without"]="w/o"
    d["within"]="w/in"; d["between"]="btwn"
    d["because"]="bc"
    d["approximately"]="~"
    d["including"]="incl"; d["excluding"]="excl"
    d["especially"]="esp"
    d["typically"]="usu"; d["usually"]="usu"
    d["generally"]="gen"
    d["immediately"]="immed"
    d["automatically"]="auto"
    d["separately"]="sep"

    prev = ""
    buf = ""       # for joining short lines
    buf_len = 0
  }

  # --- SKIP: comment-only lines ---
  /^[[:space:]]*(#[^!])/ { next }
  /^[[:space:]]*\/\// { next }
  /^[[:space:]]*\/\*/ { next }
  /^[[:space:]]*\*[[:space:]]/ { next }
  /^[[:space:]]*\*\/$/ { next }
  /^[[:space:]]*<!--/ { next }
  /^[[:space:]]*-->/ { next }

  # --- SKIP: blank lines ---
  /^[[:space:]]*$/ { next }

  # --- SKIP: decorative/divider lines ---
  /^[[:space:]]*[-=_*#~]{3,}[[:space:]]*$/ { next }
  /^[[:space:]]*[━━]+/ { next }

  {
    line = $0

    # --- CLEAN: whitespace ---
    sub(/[[:space:]]+$/, "", line)
    gsub(/\t/, " ", line)
    gsub(/  +/, " ", line)
    sub(/^[[:space:]]+/, "", line)

    # --- STRIP: inline comments (# or // after code) ---
    # Only strip if there is content before the comment marker
    if (line ~ /[^#]#[[:space:]]/ && line !~ /["'\''].*#/) {
      sub(/[[:space:]]+#[[:space:]].*$/, "", line)
    }
    if (line ~ /.\/\/[[:space:]]/ && line !~ /["'\''].*\/\//) {
      sub(/[[:space:]]+\/\/[[:space:]].*$/, "", line)
    }

    # --- CLEAN: markdown formatting ---
    # awk has no backrefs — just strip the marker characters directly
    sub(/^#{1,6}[[:space:]]+/, "", line)
    gsub(/```/, "", line)
    gsub(/`/, "", line)
    gsub(/\*\*\*/, "", line)
    gsub(/\*\*/, "", line)
    sub(/^[-*+][[:space:]]+/, "", line)
    sub(/^[0-9]+\.[[:space:]]+/, "", line)

    # --- STRIP: double quotes around single words ---
    # awk has no backrefs, so we walk and rebuild
    if (line ~ /"[^" ]+"/) {
      qresult = ""
      qrest = line
      while (match(qrest, /"[^" ]+"/)) {
        qword = substr(qrest, RSTART + 1, RLENGTH - 2)
        qresult = qresult substr(qrest, 1, RSTART - 1) qword
        qrest = substr(qrest, RSTART + RLENGTH)
      }
      line = qresult qrest
    }

    # --- FILLER PHRASE REMOVAL ---
    gsub(/[Ii]n order to/, "to", line)
    gsub(/[Aa]s well as/, "+", line)
    gsub(/[Pp]lease note that ?/, "", line)
    gsub(/[Ii]t is important to note that ?/, "", line)
    gsub(/[Ii]t should be noted that ?/, "", line)
    gsub(/[Ff]or example,? ?/, "eg ", line)
    gsub(/[Ss]uch as /, "eg ", line)
    gsub(/[Tt]hat is,? ?/, "ie ", line)
    gsub(/[Ww]ith respect to /, "re ", line)
    gsub(/[Ii]n the context of /, "in ", line)
    gsub(/[Tt]he following /, "", line)
    gsub(/[Aa]s follows:?/, ":", line)
    gsub(/[Mm]ake sure (that )?/, "", line)
    gsub(/[Kk]eep in mind (that )?/, "", line)
    gsub(/[Bb]asically,? ?/, "", line)
    gsub(/[Ee]ssentially,? ?/, "", line)
    gsub(/[Oo]bviously,? ?/, "", line)
    gsub(/[Aa]dditionally,? ?/, "+", line)
    gsub(/[Ff]urthermore,? ?/, "+", line)
    gsub(/[Mm]oreover,? ?/, "+", line)
    gsub(/[Nn]evertheless,? ?/, "but ", line)
    gsub(/[Tt]herefore,? ?/, "=> ", line)
    gsub(/[Cc]onsequently,? ?/, "=> ", line)
    gsub(/[Hh]owever,? ?/, "but ", line)
    gsub(/[Aa]lthough /, "tho ", line)
    gsub(/[Nn]ote that /, "", line)
    gsub(/[Rr]espectively/, "", line)
    gsub(/[Ss]ignificantly/, "", line)
    gsub(/[Cc]ertain /, "", line)
    gsub(/[Vv]arious /, "", line)
    gsub(/[Pp]articular /, "", line)
    gsub(/[Ss]pecific /, "", line)
    gsub(/[Dd]ifferent /, "", line)
    gsub(/[Rr]elevant /, "", line)
    gsub(/[Aa]ppropriate /, "", line)

    # --- AGGRESSIVE PROSE FILLER ---
    # Multi-word patterns that add zero information
    gsub(/[Yy]ou will need to (have )?/, "", line)
    gsub(/[Yy]ou should (also |then )?/, "", line)
    gsub(/[Yy]ou can (also |then )?/, "", line)
    gsub(/[Yy]ou may (also |want to )?/, "", line)
    gsub(/[Yy]ou must /, "", line)
    gsub(/[Ww]e will /, "", line)
    gsub(/[Ww]e have /, "", line)
    gsub(/[Ii]t is (strongly )?recommended that /, "", line)
    gsub(/[Ii]t is recommended /, "", line)
    gsub(/[Pp]lease do not hesitate to /, "", line)
    gsub(/[Ii]f you have any questions /, "", line)
    gsub(/[Ii]n this (document|guide|section),? ?/, "", line)
    gsub(/[Bb]y (running|using|following) the following (command|steps|instructions):? ?/, ": ", line)
    gsub(/[Bb]y default,? ?/, "def: ", line)
    gsub(/[Ii]n most cases,? ?/, "usu ", line)
    gsub(/[Ff]or (a |the )?basic /, "", line)
    gsub(/[Dd]epending on /, "per ", line)
    gsub(/[Tt]his (parameter|option|setting|value) (controls?|specifies|sets|determines) /, "", line)
    gsub(/[Tt]he (default|recommended) value (is|for) /, "def=", line)
    gsub(/[Ww]hich means that /, "ie ", line)
    gsub(/[Ww]hich is located at /, "@ ", line)
    gsub(/[Ww]hich are located at /, "@ ", line)
    gsub(/ is located at /, " @ ", line)
    gsub(/ are located at /, " @ ", line)
    gsub(/[Aa]fter (you have |the )?/, "after ", line)
    gsub(/[Bb]efore (you can |you )?/, "before ", line)
    gsub(/[Dd]uring the /, "during ", line)
    gsub(/[Tt]here are several /, "", line)
    gsub(/[Tt]he main /, "", line)
    gsub(/[Tt]he first step (is to |in )/, "", line)
    gsub(/[Ww]elcome to (the )?/, "", line)
    gsub(/[Cc]omprehensive /, "", line)
    gsub(/[Nn]ecessary /, "", line)
    gsub(/[Ss]uccessfully /, "", line)
    gsub(/[Pp]roperly /, "", line)
    gsub(/[Cc]orrectly /, "", line)
    gsub(/[Ff]ully /, "", line)
    gsub(/[Cc]ompletely /, "", line)
    gsub(/[Cc]urrently,? ?/, "", line)
    gsub(/[Ii]n place/, "", line)
    gsub(/ as needed/, "", line)
    gsub(/ if necessary/, "", line)
    gsub(/ at least /, " >=", line)

    # --- REMOVE ARTICLES ---
    # "the", "a", "an" are reconstructable from context.
    # Massive win on verbose prose. Safe for technical content.
    gsub(/ [Tt]he /, " ", line)
    gsub(/ [Aa]n /, " ", line)
    gsub(/ [Aa] /, " ", line)
    sub(/^[Tt]he /, "", line)
    sub(/^[Aa]n /, "", line)
    sub(/^[Aa] /, "", line)

    # --- REMOVE WEAK VERBS/FILLERS (space-bounded only) ---
    gsub(/ is /, " ", line)
    gsub(/ are /, " ", line)
    gsub(/ was /, " ", line)
    gsub(/ were /, " ", line)
    gsub(/ will be /, " ", line)
    gsub(/ has been /, " ", line)
    gsub(/ have been /, " ", line)
    gsub(/ can be /, " ", line)
    gsub(/ should be /, " ", line)
    gsub(/ would be /, " ", line)
    gsub(/ could be /, " ", line)
    gsub(/ may be /, " ", line)
    gsub(/ might be /, " ", line)
    gsub(/ needs to be /, " ", line)
    gsub(/ used to /, " ", line)
    gsub(/ also /, " ", line)
    gsub(/ just /, " ", line)
    gsub(/ very /, " ", line)
    gsub(/ really /, " ", line)
    gsub(/ quite /, " ", line)
    gsub(/ rather /, " ", line)
    gsub(/ simply /, " ", line)
    gsub(/ some /, " ", line)
    gsub(/ being /, " ", line)
    gsub(/ itself /, " ", line)
    gsub(/ themselves /, " ", line)
    gsub(/ always /, " ", line)
    gsub(/ never /, " !!", line)
    gsub(/ often /, " ", line)
    gsub(/ many /, " ", line)
    gsub(/ most /, " ", line)
    gsub(/ all of /, " all ", line)
    gsub(/ one of /, " ", line)
    gsub(/ set of /, " ", line)
    gsub(/ type of /, " ", line)
    gsub(/ kind of /, " ", line)
    gsub(/ sort of /, " ", line)
    gsub(/ based on /, " per ", line)
    gsub(/ in addition to /, " + ", line)
    gsub(/ on top of /, " + ", line)
    gsub(/ along with /, " + ", line)
    gsub(/ together with /, " + ", line)
    gsub(/ related to /, " re ", line)
    gsub(/ associated with /, " re ", line)
    gsub(/ responsible for /, " owns ", line)
    gsub(/ according to /, " per ", line)

    # --- REMOVE TRAILING PUNCTUATION ---
    sub(/\.$/, "", line)
    sub(/;$/, "", line)

    # --- WORD-BY-WORD ABBREVIATION ---
    # Portable: no \b needed. Walks each word, looks up in dictionary,
    # preserves case of first letter, reassembles with original separators.
    result = ""
    rest = line
    while (match(rest, /[a-zA-Z_][a-zA-Z0-9_]*/)) {
      word = substr(rest, RSTART, RLENGTH)
      prefix = substr(rest, 1, RSTART - 1)
      rest = substr(rest, RSTART + RLENGTH)

      lword = tolower(word)
      if (lword in d) {
        repl = d[lword]
        if (word ~ /^[A-Z]/ && repl ~ /^[a-z]/) {
          repl = toupper(substr(repl, 1, 1)) substr(repl, 2)
        }
        result = result prefix repl
      } else {
        result = result prefix word
      }
    }
    line = result rest

    # --- FINAL CLEANUP ---
    gsub(/  +/, " ", line)
    sub(/^[[:space:]]+/, "", line)
    sub(/[[:space:]]+$/, "", line)

    # skip if empty after processing
    if (line == "") next

    # --- DEDUP: skip consecutive identical lines ---
    if (line == prev) next
    prev = line

    # --- AGGRESSIVE LINE JOINING ---
    # Pack lines into 250-char blocks separated by ;
    # Gives xz much larger sliding window context for pattern matching.
    # This is the biggest single win for final compression ratio.
    cur_len = length(line)
    if (buf != "") {
      if (buf_len + cur_len + 2 < 250) {
        buf = buf "; " line
        buf_len = buf_len + cur_len + 2
        next
      } else {
        print buf
        buf = line
        buf_len = cur_len
        next
      }
    }
    buf = line
    buf_len = cur_len
    next
  }
  END {
    if (buf != "") print buf
  }
  ' "$input_file" > "$output_file"

  local comp_bytes ratio=0
  comp_bytes=$(wc -c < "$output_file" | tr -d ' ')
  if [[ "$orig_bytes" -gt 0 ]]; then
    ratio=$((comp_bytes * 100 / orig_bytes))
  fi
  info 'smash: ai: %sB -> %sB (%s%% text, before xz+b64)\n' \
    "$orig_bytes" "$comp_bytes" "$ratio"
}

# --------------------------------------------------------------------------
# LLM API semantic compression (--ai-api)
#
# Sends content through any LLM API for true semantic compression.
#
# Supports two API formats:
#   - OpenAI-compatible (default): OpenAI, Ollama, LM Studio, Groq,
#     Together, Mistral, OpenRouter, vLLM, text-generation-webui, etc.
#   - Anthropic: auto-detected from URL containing "anthropic.com"
#
# Security: API keys and payloads are passed via temp files (curl -K
# and -d @file), never on the command line where ps(1) would expose them.
# API responses are never printed raw: error excerpts pass through sn().
# --------------------------------------------------------------------------
ai_compress_api() {
  local input_file="$1" output_file="$2"

  command -v jq >/dev/null 2>&1 || die "--ai-api requires jq"
  command -v curl >/dev/null 2>&1 || die "--ai-api requires curl"

  local api_url="${B64_AI_URL:-}"
  local api_key="${B64_AI_KEY:-}"
  local model="${B64_AI_MODEL:-}"
  local is_anthropic=0
  local is_local=0

  # --- Auto-detect provider from env vars ---
  if [[ -z "$api_url" ]]; then
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
      api_url="https://api.anthropic.com/v1/messages"
      api_key="${api_key:-$ANTHROPIC_API_KEY}"
      model="${model:-claude-sonnet-4-6}"
      is_anthropic=1
    elif [[ -n "${OPENAI_API_KEY:-}" ]]; then
      api_url="https://api.openai.com/v1/chat/completions"
      api_key="${api_key:-$OPENAI_API_KEY}"
      model="${model:-gpt-4o-mini}"
    else
      die "--ai-api needs: B64_AI_URL, or ANTHROPIC_API_KEY, or OPENAI_API_KEY"
    fi
  else
    # URL provided — detect format
    if [[ "$api_url" == *"anthropic.com"* ]]; then
      is_anthropic=1
      api_key="${api_key:-${ANTHROPIC_API_KEY:-}}"
      model="${model:-claude-sonnet-4-6}"
    else
      api_key="${api_key:-${OPENAI_API_KEY:-}}"
      model="${model:-gpt-4o-mini}"
    fi

    # Local endpoints (Ollama, LM Studio) don't need a key
    if [[ "$api_url" == *"localhost"* || "$api_url" == *"127.0.0.1"* || "$api_url" == *"0.0.0.0"* ]]; then
      is_local=1
      model="${model:-llama3}"
    fi
  fi

  if [[ "$is_local" -eq 0 && -z "$api_key" ]]; then
    die "--ai-api needs B64_AI_KEY or provider-specific key env var"
  fi

  local orig_bytes
  orig_bytes=$(wc -c < "$input_file" | tr -d ' ')

  if [[ "$orig_bytes" -gt 512000 ]]; then
    info 'smash: warning: large input (%sB) — may hit token limits\n' "$orig_bytes"
  fi

  info 'smash: ai-api compressing %sB via %s@%s...\n' \
    "$orig_bytes" "$(sn "$model")" "$(sn "${api_url##*/}")"

  local sys_prompt
  sys_prompt="You are a precision compression engine. Distill the input to its absolute essence.

RULES:
- Preserve ALL: facts, numbers, values, names, paths, configs, code, schemas, relationships, constraints
- Remove ONLY: redundancy, verbose explanation, filler words, repeated context
- Use dense shorthand: abbreviations, compact notation, implied structure
- Reference well-known concepts by name instead of explaining them
- For code: keep logic and structure, strip comments and whitespace
- For configs: keep all keys and values, compact formatting
- For prose: extract facts and relationships, drop narrative
- NEVER add commentary, framing, or meta-text about the compression
- NEVER omit information — compress representation, not content
- Target: 10% of input size or less"

  local response compressed

  # Build payload to temp file (avoids ARG_MAX, hidden from ps)
  TMP_PAYLOAD="$(mktemp "${SMASH_TMP}/smash.payload.XXXXXX")"

  if [[ "$is_anthropic" -eq 1 ]]; then
    # --- Anthropic Messages API ---
    jq -Rs \
      --arg model "$model" \
      --arg sys "$sys_prompt" \
      '{
        model: $model,
        max_tokens: 16384,
        system: $sys,
        messages: [{role: "user", content: .}]
      }' < "$input_file" > "$TMP_PAYLOAD" || { rm -f "$TMP_PAYLOAD"; die "failed to build payload (jq)"; }

    TMP_CURLCFG="$(mktemp "${SMASH_TMP}/smash.curl.XXXXXX")"
    printf 'header = "x-api-key: %s"\n' "$api_key" > "$TMP_CURLCFG"
    response=$(curl -sS --max-time 300 \
      -K "$TMP_CURLCFG" \
      "$api_url" \
      -H "anthropic-version: 2023-06-01" \
      -H "content-type: application/json" \
      -d "@${TMP_PAYLOAD}" 2>&1) || { rm -f "$TMP_CURLCFG" "$TMP_PAYLOAD"; die "API call failed"; }
    rm -f "$TMP_CURLCFG" "$TMP_PAYLOAD"; TMP_CURLCFG=""; TMP_PAYLOAD=""

    compressed=$(printf '%s\n' "$response" | jq -r '.content[0].text // empty' 2>/dev/null) || true
  else
    # --- OpenAI-compatible Chat Completions API ---
    jq -Rs \
      --arg model "$model" \
      --arg sys "$sys_prompt" \
      '{
        model: $model,
        max_tokens: 16384,
        messages: [
          {role: "system", content: $sys},
          {role: "user", content: .}
        ]
      }' < "$input_file" > "$TMP_PAYLOAD" || { rm -f "$TMP_PAYLOAD"; die "failed to build payload (jq)"; }

    if [[ -n "$api_key" ]]; then
      TMP_CURLCFG="$(mktemp "${SMASH_TMP}/smash.curl.XXXXXX")"
      printf 'header = "Authorization: Bearer %s"\n' "$api_key" > "$TMP_CURLCFG"
      response=$(curl -sS --max-time 300 \
        -K "$TMP_CURLCFG" \
        "$api_url" \
        -H "content-type: application/json" \
        -d "@${TMP_PAYLOAD}" 2>&1) || { rm -f "$TMP_CURLCFG" "$TMP_PAYLOAD"; die "API call failed"; }
      rm -f "$TMP_CURLCFG" "$TMP_PAYLOAD"; TMP_CURLCFG=""; TMP_PAYLOAD=""
    else
      response=$(curl -sS --max-time 300 \
        "$api_url" \
        -H "content-type: application/json" \
        -d "@${TMP_PAYLOAD}" 2>&1) || { rm -f "$TMP_PAYLOAD"; die "API call failed"; }
      rm -f "$TMP_PAYLOAD"; TMP_PAYLOAD=""
    fi

    compressed=$(printf '%s\n' "$response" | jq -r '.choices[0].message.content // empty' 2>/dev/null) || true
  fi

  if [[ -z "$compressed" ]]; then
    local err_msg
    err_msg=$(printf '%s\n' "$response" | jq -r '.error.message // .error.type // .detail // empty' 2>/dev/null) || true
    [[ -n "$err_msg" ]] || err_msg="$(printf '%s\n' "$response" | head -c 200)"
    die "API returned no content: $err_msg"
  fi

  printf '%s' "$compressed" > "$output_file"

  local comp_bytes ratio=0
  comp_bytes=$(wc -c < "$output_file" | tr -d ' ')
  if [[ "$orig_bytes" -gt 0 ]]; then
    ratio=$((comp_bytes * 100 / orig_bytes))
  fi
  info 'smash: ai-api: %sB -> %sB (%s%% text, before xz+b64)\n' \
    "$orig_bytes" "$comp_bytes" "$ratio"
}

# ---- parse args ----
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    -V|--version) printf 'smash v%s\n' "$VERSION"; exit 0 ;;
    -d|--decode) ACTION="decode"; shift ;;
    -x|--xz) COMPRESS_MODE="xz"; shift ;;
    -g|--gz) COMPRESS_MODE="gz"; shift ;;
    -z|--zstd|--zst)
      command -v zstd >/dev/null 2>&1 || die "--zstd requires zstd"
      COMPRESS_MODE="zstd"; shift ;;
    --ai) AI_MODE=1; COMPRESS_MODE="xz"; shift ;;
    --ai-api) AI_API_MODE=1; COMPRESS_MODE="xz"; shift ;;
    -s) [[ $# -ge 2 ]] || usage; MODE="string"; TEXT="$2"; shift 2 ;;
    -o|--output) [[ $# -ge 2 ]] || usage; OUT_PATH="$2"; shift 2 ;;
    -q|--quiet) QUIET=1; shift ;;
    --level) [[ $# -ge 2 ]] || usage; [[ "$2" =~ ^[0-9]+$ ]] || die "--level needs an integer"; LEVEL="$2"; shift 2 ;;
    --threads) [[ $# -ge 2 ]] || usage; [[ "$2" =~ ^[0-9]+$ ]] || die "--threads needs an integer"; THREADS="$2"; shift 2 ;;
    --edit) MODE="edit"; shift ;;
    --)
      # Everything after -- is an operand, verbatim (v5.0 fix: these were
      # silently dropped before).
      shift
      while [[ $# -gt 0 ]]; do OPERANDS+=("$1"); shift; done
      break ;;
    -)
      USE_STDIN=1; shift ;;
    -*) die "unknown option: $1" ;;
    *)
      OPERANDS+=("$1"); shift ;;
  esac
done

# AI modes always wrap in xz (the .ai.xz contract) regardless of -g/-z order.
if [[ "$AI_MODE" -eq 1 || "$AI_API_MODE" -eq 1 ]]; then
  COMPRESS_MODE="xz"
fi

# Select which AI compressor to use (if any)
ai_fn=""
if [[ "$AI_API_MODE" -eq 1 ]]; then
  ai_fn="ai_compress_api"
elif [[ "$AI_MODE" -eq 1 ]]; then
  ai_fn="ai_compress"
fi

N_OPS=${#OPERANDS[@]}

# is_text_file: best-effort text check for the --ai guard. If file(1) is
# missing, assume text (legacy behavior).
is_text_file() {
  command -v file >/dev/null 2>&1 || return 0
  local mt
  mt="$(file -b --mime-type -- "$1" 2>/dev/null)" || return 0
  case "$mt" in
    text/*|application/json|application/xml|application/javascript|inode/x-empty) return 0 ;;
    *) return 1 ;;
  esac
}

# resolve OUTDIR for encode. -o rules:
#   existing dir or trailing /  -> output directory
#   otherwise, single input     -> filename prefix (artifact keeps ext chain)
#   otherwise (multi input)     -> created as a directory
OUTDIR=""
OUT_PREFIX=""
OUTDIR_AUTO=0   # 1 = no -o/B64_OUTDIR: each artifact lands beside its input
resolve_encode_out() {
  local n_inputs="$1" first_input="$2"
  if [[ -n "$OUT_PATH" ]]; then
    if [[ -d "$OUT_PATH" || "$OUT_PATH" == */ ]]; then
      OUTDIR="${OUT_PATH%/}"
      ensure_outdir "$OUTDIR" || die "cannot write to output dir: $(sn "$OUTDIR")"
    elif [[ "$n_inputs" -gt 1 ]]; then
      OUTDIR="$OUT_PATH"
      ensure_outdir "$OUTDIR" || die "cannot write to output dir: $(sn "$OUTDIR")"
    else
      OUT_PREFIX="$OUT_PATH"
      OUTDIR="$(dirname -- "$OUT_PATH")"
      ensure_outdir "$OUTDIR" || die "cannot write to output dir: $(sn "$OUTDIR")"
    fi
    # v5.1: an EXPLICIT -o into a web-served/live dir refuses rather than
    # silently redirecting — the user stated intent, so make them mean it.
    if is_unsafe_dir "$OUTDIR" && [[ "${SMASH_ALLOW_UNSAFE_OUTDIR:-0}" != "1" ]]; then
      die "refusing -o into a web-served/live dir: $(sn "$OUTDIR") (deliberate? SMASH_ALLOW_UNSAFE_OUTDIR=1)"
    fi
    return 0
  fi
  if [[ -n "${B64_OUTDIR:-}" ]]; then
    OUTDIR="$B64_OUTDIR"
  elif [[ -n "$first_input" ]]; then
    OUTDIR="$(dirname -- "$first_input")"
    OUTDIR_AUTO=1
  else
    OUTDIR="${HOME:-/tmp}/smashes"
  fi
  if ! ensure_outdir "$OUTDIR"; then
    local fallback="${HOME:-/tmp}/smashes"
    ensure_outdir "$fallback" || die "cannot write to output dir"
    OUTDIR="$fallback"
  fi
  OUTDIR="$(guard_outdir "$OUTDIR" "output")"
}

# ==========================================================================
# encode_one: encode a single staged source file into one artifact.
#   $1 = source file path (regular file, already staged/validated)
#   $2 = display label for the manifest (sanitized at write time)
#   $3 = kind label (file | dir-tar | inline-args(N) | stdin | string | edit)
#   $4 = base name for the artifact
# ==========================================================================
encode_one() {
  local src="$1" label="$2" kind="$3" base="$4"
  local ext_label lossy="no" use_ai="$ai_fn"

  # --ai on non-text content would mangle bytes through the awk compactor;
  # fall back to lossless for that input (loud, once per input).
  if [[ -n "$use_ai" && "$kind" == "file" ]] && ! is_text_file "$src"; then
    warn "note: $(sn "$label") is not text — using lossless xz (no --ai) for it"
    use_ai=""
  fi

  if [[ -n "$use_ai" ]]; then
    ext_label="ai.xz"
    lossy="yes"
  elif [[ "$COMPRESS_MODE" == "zstd" ]]; then
    ext_label="zst"
  else
    ext_label="$COMPRESS_MODE"
  fi

  local src_bytes src_sum
  src_bytes=$(wc -c < "$src" | tr -d ' ')
  src_sum="$(sha256_file "$src")"

  TMP_B64="$(mktemp "${SMASH_TMP}/smash.stage.XXXXXX.b64")"

  if [[ -n "$use_ai" ]]; then
    TMP_AI="$(mktemp "${SMASH_TMP}/smash.ai.XXXXXX")"
    "$use_ai" "$src" "$TMP_AI"
    encode_to_tmp "$TMP_B64" < "$TMP_AI"
    rm -f "$TMP_AI"; TMP_AI=""
  else
    encode_to_tmp "$TMP_B64" < "$src"
  fi

  # Assemble final artifact: manifest header + payload + trailing newline.
  TMP_FINAL="$(mktemp "${SMASH_TMP}/smash.final.XXXXXX")"
  write_manifest "$TMP_FINAL" "$label" "$kind" "$src_bytes" "$src_sum" "$ext_label" "$lossy"
  cat "$TMP_B64" >> "$TMP_FINAL"
  printf '\n' >> "$TMP_FINAL"
  rm -f "$TMP_B64"; TMP_B64=""

  # Verify the exact bytes we are about to ship decode cleanly.
  if ! verify_artifact "$TMP_FINAL" "$COMPRESS_MODE"; then
    die "verify failed: artifact corrupt. staged file: $TMP_FINAL"
  fi

  local final_out final_bytes
  if [[ -n "$OUT_PREFIX" ]]; then
    final_out="$(pick_outfile "$(dirname -- "$OUT_PREFIX")" "$OUT_PREFIX")"
  else
    final_out="$(pick_outfile "$OUTDIR" "$base")"
  fi

  final_bytes=$(wc -c < "$TMP_FINAL" | tr -d ' ')
  if [[ "$src_bytes" -gt 0 ]]; then
    info 'smash: total: %sB -> %sB artifact (%s%%)\n' \
      "$src_bytes" "$final_bytes" "$((final_bytes * 100 / src_bytes))"
  fi

  move_final "$TMP_FINAL" "$final_out"
  TMP_FINAL=""
  info 'encoded: %s\n' "$(sn "$final_out")"
}

# encode_path: stage one operand (file or directory) and encode it.
encode_path() {
  local input="$1"
  input="${input%/}"
  local base
  base="$(safe_base "$input")"

  # Default output placement: each artifact lands beside its own input
  # (multi-input runs may span directories).
  if [[ "$OUTDIR_AUTO" -eq 1 ]]; then
    OUTDIR="$(dirname -- "$input")"
    ensure_outdir "$OUTDIR" || OUTDIR="${HOME:-/tmp}/smashes"
    ensure_outdir "$OUTDIR" || die "cannot write to output dir"
    OUTDIR="$(guard_outdir "$OUTDIR" "auto-output")"
  fi

  # v5.1: reading from a web-served/live tree is fine — note it once so the
  # operator knows the artifact will not land there.
  local in_dir="$input"
  [[ -d "$input" ]] || in_dir="$(dirname -- "$input")"
  if is_unsafe_dir "$in_dir"; then
    info 'smash: NOTE: input lives on a web-served/live tree (%s) — read-only; artifact goes to a safe dir\n' "$(sn "$input")"
  fi

  if [[ -d "$input" ]]; then
    # --- Directory: optionally AI-compress text files, then tar + encode ---
    local dir_parent dir_base src_mode_before src_mode_after
    dir_parent="$(dirname -- "$input")"
    dir_base="$(basename -- "$input")"
    src_mode_before="$(stat -f '%Lp' "$input" 2>/dev/null || stat -c '%a' "$input" 2>/dev/null || echo '?')"
    TMP_TAR="$(mktemp "${SMASH_TMP}/smash.tar.XXXXXX.tar")"

    if [[ -n "$ai_fn" ]]; then
      TMP_AIDIR="$(mktemp -d "${SMASH_TMP}/smash.aidir.XXXXXX")"
      cp -a -- "$input" "$TMP_AIDIR/"
      local ai_count=0 ai_skip=0 f
      while IFS= read -r -d '' f; do
        if is_text_file "$f"; then
          TMP_AF="$(mktemp "${SMASH_TMP}/smash.af.XXXXXX")"
          "$ai_fn" "$f" "$TMP_AF"
          mv -f -- "$TMP_AF" "$f"
          TMP_AF=""
          ai_count=$((ai_count + 1))
        else
          ai_skip=$((ai_skip + 1))
        fi
      done < <(find "$TMP_AIDIR/$dir_base" -type f -print0)
      info 'smash: ai: %s text files compressed, %s binary kept as-is\n' \
        "$ai_count" "$ai_skip"
      tar cf "$TMP_TAR" -C "$TMP_AIDIR" -- "$dir_base" || die "tar failed"
      rm -rf "$TMP_AIDIR"; TMP_AIDIR=""
    else
      info 'smash: tarring directory: %s\n' "$(sn "$input")"
      tar cf "$TMP_TAR" -C "$dir_parent" -- "$dir_base" || die "tar failed on: $(sn "$input")"
    fi

    # v5.1 source-immutability self-check: encode must never alter the source.
    src_mode_after="$(stat -f '%Lp' "$input" 2>/dev/null || stat -c '%a' "$input" 2>/dev/null || echo '?')"
    if [[ "$src_mode_before" != "$src_mode_after" ]]; then
      warn "WARNING: source dir mode changed during encode ($src_mode_before -> $src_mode_after) — THIS IS A smash BUG, report it"
    fi

    local tar_bytes
    tar_bytes=$(wc -c < "$TMP_TAR" | tr -d ' ')
    info 'smash: tar: %sB\n' "$tar_bytes"
    encode_one "$TMP_TAR" "$input" "dir-tar" "$base"
    rm -f "$TMP_TAR"; TMP_TAR=""
  else
    encode_one "$input" "$input" "file" "$base"
  fi
}

# ==========================================================================
# decode_one: decode a single artifact.
# ==========================================================================
DEC_OUT_DIR=""     # -o as directory for decode (multi or explicit dir)
DEC_OUT_FILE=""    # -o as exact file path (single decode only)

decode_one() {
  local infile="$1"
  local dir name
  dir="$(dirname -- "$infile")"
  name="$(basename -- "$infile")"

  [[ -r "$infile" && -f "$infile" ]] || die "not a readable file: $(sn "$infile")"

  # Read the self-describing manifest first. New readable artifact names no
  # longer duplicate compression, timestamp, or directory type in the name.
  local manifest_source manifest_kind manifest_encoding
  manifest_source="$(sed -n 's/^# source: \(.*\) | kind: .*/\1/p' "$infile" | head -n 1)"
  manifest_kind="$(sed -n 's/^# source: .* | kind: \([^|]*\) | bytes:.*/\1/p' "$infile" | head -n 1)"
  manifest_encoding="$(sed -n 's/^# encoding: \(.*\) | lossy:.*/\1/p' "$infile" | head -n 1)"

  # Detect directory tar from the manifest, retaining old .dtar compatibility.
  local is_dtar=0
  if [[ "$manifest_kind" == "dir-tar" || "$name" == *".dtar."* || "$name" == *".dtar" ]]; then
    is_dtar=1
  fi

  # Auto-detect compression and AI mode from extension. Works with both the
  # v5 (.b64.<ts>.txt) and pre-v5 (.b64.<ts>) artifact names.
  local is_ai=0 decomp="xz" ext_pattern="xz"
  if [[ "$manifest_encoding" == *"zstd("* || "$manifest_encoding" == *"zst("* ]]; then
    decomp="zstd"; ext_pattern="zst"
  elif [[ "$manifest_encoding" == *"gzip("* || "$manifest_encoding" == *"gz("* ]]; then
    decomp="gz"; ext_pattern="gz"
  elif [[ "$manifest_encoding" == *"ai"* ]]; then
    decomp="xz"; is_ai=1; ext_pattern="ai.xz"
  elif [[ "$manifest_encoding" == *"xz("* ]]; then
    decomp="xz"; ext_pattern="xz"
  elif [[ "$name" == *".ai.xz.b64"* ]]; then
    decomp="xz"; is_ai=1; ext_pattern="ai.xz"
  elif [[ "$name" == *".xz.b64"* ]]; then
    decomp="xz"; ext_pattern="xz"
  elif [[ "$name" == *".gz.b64"* ]]; then
    decomp="gz"; ext_pattern="gz"
  elif [[ "$name" == *".zst.b64"* ]]; then
    decomp="zstd"; ext_pattern="zst"
  fi

  # Fail fast if the decoder for this payload isn't installed on this host.
  [[ "$decomp" != "zstd" ]] || command -v zstd >/dev/null 2>&1 || die "decoding .zst payloads requires zstd"

  local out_path=""
  if [[ -n "$DEC_OUT_FILE" ]]; then
    out_path="$DEC_OUT_FILE"
  else
    local bare="$name"
    if [[ -n "$manifest_source" ]]; then
      bare="$(safe_base "$manifest_source")"
      [[ "$is_dtar" -eq 0 ]] || bare="${bare}.dtar"
    elif [[ "$bare" == *".${ext_pattern}.b64."* ]]; then
      bare="${bare%%.${ext_pattern}.b64.*}"
    elif [[ "$bare" == *.${ext_pattern}.b64 ]]; then
      bare="${bare%.${ext_pattern}.b64}"
    else
      bare="$(printf '%s' "$bare" | sed -E 's/\.smash(\.[0-9]+)?\.txt$//')"
    fi
    [[ -n "$bare" ]] || bare="restored"

    local target_dir="$dir"
    [[ -n "$DEC_OUT_DIR" ]] && target_dir="$DEC_OUT_DIR"

    local candidate="${target_dir}/${bare}"
    if [[ -e "$candidate" ]]; then
      candidate="$(pick_unique "${target_dir}/${bare}.restored.$(short_ts)")"
    fi
    out_path="$candidate"
  fi

  local out_dir
  out_dir="$(dirname -- "$out_path")"
  [[ -d "$out_dir" ]] || mkdir -p "$out_dir" 2>/dev/null || die "cannot create output dir: $(sn "$out_dir")"
  [[ -w "$out_dir" ]] || die "output dir not writable: $(sn "$out_dir")"

  TMP_OUT="$(mktemp "${SMASH_TMP}/smash.stage.XXXXXX")"

  decode_to_tmp "$TMP_OUT" "$decomp" < "$infile" || die "decompression or decode failed: $(sn "$infile")"
  if [[ ! -s "$TMP_OUT" ]]; then
    warn "note: $(sn "$name") restored as an empty file (source was empty)"
  fi

  # v5.1: decoding a single file INTO a web-served/live dir stays allowed
  # (deliberate restores) but is always called out.
  if is_unsafe_dir "$(dirname -- "$out_path")"; then
    info 'smash: NOTE: decoding into a web-served/live dir: %s\n' "$(sn "$out_path")"
  fi

  move_final "$TMP_OUT" "$out_path"
  TMP_OUT=""

  # Auto-extract directory tars (.dtar)
  if [[ "$is_dtar" -eq 1 ]]; then
    local extract_dir extracted_name
    extract_dir="$(dirname -- "$out_path")"
    extracted_name="$(basename -- "$out_path" .dtar)"
    # v5.1: mass-overwrite into a live webroot must be deliberate.
    if is_unsafe_dir "$extract_dir" && [[ "${SMASH_ALLOW_UNSAFE_OUTDIR:-0}" != "1" ]]; then
      die "refusing to auto-extract a directory tar into a web-served/live dir: $(sn "$extract_dir") (deliberate? SMASH_ALLOW_UNSAFE_OUTDIR=1; artifact kept: $(sn "$out_path"))"
    fi
    info 'smash: extracting directory to: %s/%s\n' "$(sn "$extract_dir")" "$(sn "$extracted_name")"
    # Harden: payloads may be untrusted. Reject any archive member that escapes
    # the extraction dir via an absolute path or a `..` traversal component.
    if tar tf "$out_path" 2>/dev/null | grep -Eq '^/|(^|/)\.\.(/|$)'; then
      die "refusing to extract: archive contains absolute or traversal paths"
    fi
    # Preserve normal source permissions. Extraction is staged privately;
    # ownership is not restored and only dangerous permission bits are removed.
    safe_extract_dtar "$out_path" "$extract_dir"
    rm -f -- "$out_path"
    if [[ "$is_ai" -eq 1 ]]; then
      info 'decoded+extracted (ai-compacted, lossy): %s/%s\n' "$(sn "$extract_dir")" "$(sn "$extracted_name")"
    else
      info 'decoded+extracted: %s/%s\n' "$(sn "$extract_dir")" "$(sn "$extracted_name")"
    fi
  elif [[ "$is_ai" -eq 1 ]]; then
    info 'decoded (ai-compacted, lossy): %s\n' "$(sn "$out_path")"
  else
    info 'decoded: %s\n' "$(sn "$out_path")"
  fi
}

if [[ "$ACTION" == "decode" ]]; then
  # ==========================================
  # DECODE
  # ==========================================
  if [[ "$USE_STDIN" -eq 1 ]]; then
    # smash -d - : artifact arrives on stdin (piped or pasted). Without -o
    # the restored file lands in the current directory, not $TMPDIR.
    TMP_STDIN="$(mktemp "${SMASH_TMP}/smash.in.XXXXXX")"
    cat > "$TMP_STDIN"
    OPERANDS+=("$TMP_STDIN")
    N_OPS=${#OPERANDS[@]}
    if [[ -z "$OUT_PATH" && "$N_OPS" -eq 1 ]]; then
      OUT_PATH="$(pick_unique "./restored.$(short_ts)")"
    fi
  fi
  [[ "$N_OPS" -gt 0 ]] || usage

  # -o with multiple artifacts must be a directory; with one artifact an
  # existing dir (or trailing /) is a dir, anything else is the exact path.
  if [[ -n "$OUT_PATH" ]]; then
    if [[ "$N_OPS" -gt 1 || -d "$OUT_PATH" || "$OUT_PATH" == */ ]]; then
      DEC_OUT_DIR="${OUT_PATH%/}"
      ensure_outdir "$DEC_OUT_DIR" || die "cannot write to output dir: $(sn "$DEC_OUT_DIR")"
    else
      DEC_OUT_FILE="$OUT_PATH"
    fi
  fi

  for op in "${OPERANDS[@]}"; do
    decode_one "$op"
  done
  if [[ "$N_OPS" -gt 1 ]]; then
    info 'smash: decoded %s artifacts\n' "$N_OPS"
  fi
  # Remove a staged stdin copy promptly (it may hold sensitive payload bytes).
  [[ -z "${TMP_STDIN:-}" ]] || { rm -f "$TMP_STDIN"; TMP_STDIN=""; }
  exit 0

else
  # ==========================================
  # ENCODE
  # ==========================================

  if [[ "$USE_STDIN" -eq 1 && "$N_OPS" -gt 0 ]]; then
    die "cannot mix - (stdin) with file operands in one run"
  fi
  if [[ "$MODE" == "string" && "$N_OPS" -gt 0 ]]; then
    die "cannot mix -s with file operands in one run"
  fi

  if [[ "$N_OPS" -gt 0 ]]; then
    # ---- classify operands: file list vs inline text (the `smash \`cmd\``
    # ---- and `smash word word` cases) ----
    N_EXIST=0
    MISSING=""
    for op in "${OPERANDS[@]}"; do
      if [[ -e "${op%/}" || -L "${op%/}" ]]; then
        N_EXIST=$((N_EXIST + 1))
      else
        MISSING="${MISSING}${MISSING:+, }$(sn "$op")"
      fi
    done

    if [[ "$N_EXIST" -eq "$N_OPS" ]]; then
      # Every operand exists: encode each one. Validate all BEFORE writing
      # anything so a bad operand can't leave a half-finished batch.
      for op in "${OPERANDS[@]}"; do
        p="${op%/}"
        if [[ -d "$p" ]]; then
          [[ -r "$p" && -x "$p" ]] || die "directory not readable: $(sn "$p")"
        elif [[ -f "$p" ]]; then
          [[ -r "$p" ]] || die "file not readable: $(sn "$p")"
        else
          die "unsupported file type (not a regular file or directory): $(sn "$p")"
        fi
      done
      resolve_encode_out "$N_OPS" "${OPERANDS[0]%/}"
      if [[ -n "$OUT_PREFIX" && "$N_OPS" -gt 1 ]]; then
        die "-o filename prefix needs a single input (use a directory)"
      fi
      for op in "${OPERANDS[@]}"; do
        encode_path "$op"
      done
      if [[ "$N_OPS" -gt 1 ]]; then
        info 'smash: %s artifacts written\n' "$N_OPS"
      fi
      exit 0
    fi

    if [[ "$N_OPS" -eq 1 || $((N_EXIST * 2)) -ge "$N_OPS" ]]; then
      # One operand, or a mostly-real file list: missing names are a typo,
      # not prose. Fail loudly instead of silently encoding junk.
      die "not a readable file or directory: $MISSING"
    fi

    # Mostly non-files (e.g. smash `ps auxww`): treat the whole argument
    # vector as one inline-text payload. Always announced, even with -q,
    # because it changes what the artifact IS.
    warn "note: $((N_OPS - N_EXIST)) of $N_OPS operands are not files — encoding all $N_OPS args as one inline-text payload (use quotes, -s, or a pipe to be explicit)"
    resolve_encode_out 1 ""
    TMP_STDIN="$(mktemp "${SMASH_TMP}/smash.in.XXXXXX")"
    printf '%s' "${OPERANDS[*]}" > "$TMP_STDIN"
    encode_one "$TMP_STDIN" "command-line arguments" "inline-args(${N_OPS})" "command-line-text"
    rm -f "$TMP_STDIN"; TMP_STDIN=""
    exit 0
  fi

  # ---- no operands: string / edit / stdin modes ----
  resolve_encode_out 1 ""

  case "$MODE" in
    string)
      TMP_STDIN="$(mktemp "${SMASH_TMP}/smash.in.XXXXXX")"
      printf '%s' "$TEXT" > "$TMP_STDIN"
      encode_one "$TMP_STDIN" "string (-s)" "string" "pasted-text"
      rm -f "$TMP_STDIN"; TMP_STDIN=""
      ;;
    edit)
      TMP_TXT="$(mktemp "${SMASH_TMP}/smash.edit.XXXXXX")"
      : > "$TMP_TXT"
      # Resolve an editor into an argv array. $VISUAL/$EDITOR may be
      # multi-word (e.g. "code --wait"); if neither is set, fall back
      # through real editors.
      ed_cmd=()
      if [[ -n "${VISUAL:-}" ]]; then
        read -r -a ed_cmd <<< "$VISUAL"
      elif [[ -n "${EDITOR:-}" ]]; then
        read -r -a ed_cmd <<< "$EDITOR"
      else
        for _cand in nano pico vi vim; do
          if command -v "$_cand" >/dev/null 2>&1; then
            if [[ "$_cand" == "nano" ]]; then ed_cmd=(nano -w); else ed_cmd=("$_cand"); fi
            break
          fi
        done
      fi
      [[ ${#ed_cmd[@]} -gt 0 ]] || die "--edit needs a working \$EDITOR/\$VISUAL or one of: nano pico vi vim"
      command -v "${ed_cmd[0]}" >/dev/null 2>&1 || die "editor not found in PATH: ${ed_cmd[0]}"
      "${ed_cmd[@]}" "$TMP_TXT"
      encode_one "$TMP_TXT" "editor session" "edit" "edited-text"
      rm -f "$TMP_TXT"; TMP_TXT=""
      ;;
    auto)
      # stdin: explicit `-`, piped/redirected input, or interactive paste.
      if [[ -t 0 && "$USE_STDIN" -eq 0 ]]; then
        cat 1>&2 <<'PROMPT'
smash: Interactive input mode
------------------------------------------------------------------
Paste your text below (unlimited size, any characters).
Press Ctrl+D on a new line when finished.
------------------------------------------------------------------
PROMPT
      fi
      TMP_STDIN="$(mktemp "${SMASH_TMP}/smash.in.XXXXXX")"
      cat > "$TMP_STDIN"
      [[ -t 0 ]] && printf '\n' 1>&2
      stream_label="stdin stream"
      [[ -z "$OUT_PREFIX" ]] || stream_label="$(basename -- "$OUT_PREFIX")"
      encode_one "$TMP_STDIN" "$stream_label" "stdin" "piped-text"
      rm -f "$TMP_STDIN"; TMP_STDIN=""
      ;;
    *)
      die "internal mode error"
      ;;
  esac
  exit 0
fi
